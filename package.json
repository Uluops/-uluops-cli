{
  "name": "@uluops/cli",
  "version": "0.14.0",
  "description": "Unified CLI for UluOps - validation tracking and registry management",
  "type": "module",
  "bin": {
    "ulu": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "exports": {
    "./cli": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "NODE_ENV=development tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "prepublishOnly": "npm run lint && npm test && npm audit --audit-level=high --omit=dev && npm run build"
  },
  "keywords": [
    "uluops",
    "cli",
    "validation",
    "registry",
    "agents",
    "workflows"
  ],
  "author": "UluOps",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Uluops/-uluops-cli.git"
  },
  "license": "MIT",
  "dependencies": {
    "@uluops/core": "0.18.5",
    "@uluops/ops-sdk": "3.2.1",
    "@uluops/registry-sdk": "0.31.1",
    "commander": "13.1.0",
    "ora": "8.1.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@types/node": "22.12.0",
    "@vitest/coverage-v8": "3.2.6",
    "tsx": "4.19.2",
    "typescript": "5.7.3",
    "vitest": "3.2.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
