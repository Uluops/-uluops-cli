{
  "name": "@uluops/cli",
  "version": "0.4.0",
  "description": "Unified CLI for UluOps - validation tracking and registry management",
  "type": "module",
  "bin": {
    "ulu": "dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "exports": {
    "./cli": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "NODE_ENV=development tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "uluops",
    "cli",
    "validation",
    "registry",
    "agents",
    "workflows"
  ],
  "author": "UluOps",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Uluops/-uluops-cli.git"
  },
  "license": "MIT",
  "dependencies": {
    "@uluops/core": "^0.13.0",
    "@uluops/ops-sdk": "^1.9.0",
    "@uluops/registry-sdk": "^0.26.0",
    "@uluops/sdk-core": "^0.10.0",
    "commander": "^13.1.0",
    "ora": "^8.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@vitest/coverage-v8": "^3.0.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
